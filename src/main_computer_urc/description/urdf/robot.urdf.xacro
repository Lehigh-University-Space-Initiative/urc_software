<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rover">


  <!-- Base Link -->
  <link name="base_link"/>


  <!-- Wheels -->
  <link name="lf_wheel_link"/>
  <link name="lm_wheel_link"/>
  <link name="lb_wheel_link"/>
  <link name="rf_wheel_link"/>
  <link name="rm_wheel_link"/>
  <link name="rb_wheel_link"/>


  <!-- Joints -->
  <joint name="lf_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="lf_wheel_link"/>
    <origin xyz="0.5 0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="lm_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="lm_wheel_link"/>
    <origin xyz="0.0 0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="lb_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="lb_wheel_link"/>
    <origin xyz="-0.5 0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="rf_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rf_wheel_link"/>
    <origin xyz="0.5 -0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="rm_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rm_wheel_link"/>
    <origin xyz="0.0 -0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="rb_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rb_wheel_link"/>
    <origin xyz="-0.5 -0.5 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- ros2_control Integration -->
  <ros2_control name="RoverHardware" type="system">
    <hardware>
      <plugin>drive_train_hardware/DriveTrainHardware</plugin>
    </hardware>


    <joint name="lf_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


    <joint name="lm_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


    <joint name="lb_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


    <joint name="rf_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


    <joint name="rm_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


    <joint name="rb_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>


  </ros2_control>


</robot>





